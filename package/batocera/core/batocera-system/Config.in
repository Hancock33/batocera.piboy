config BR2_PACKAGE_BATOCERA_PORTS_SYSTEMS
    bool "batocera.linux ports packages"

    # DevilutionX (Diablo 1)
    select BR2_PACKAGE_DEVILUTIONX

    # Cannonball (OutRun)
    select BR2_PACKAGE_CANNONBALL

    # PrBoom (Doom)
    select BR2_PACKAGE_LIBRETRO_PRBOOM

    # TyrQuake (Quake 1)
    select BR2_PACKAGE_LIBRETRO_TYRQUAKE
    select BR2_PACKAGE_VKQUAKE                              if  BR2_PACKAGE_BATOCERA_VULKAN

    # NxEngine (Cave Story)
    select BR2_PACKAGE_LIBRETRO_NXENGINE

    # MrBoom (Bomberman clone)
    select BR2_PACKAGE_LIBRETRO_MRBOOM

    # Prince of Persia
    select BR2_PACKAGE_SDLPOP

    # Xash3D-FWGS (Half-Life 1)
    select BR2_PACKAGE_XASH3D_FWGS

    # Commander Genius (Commander Keen series)
    select BR2_PACKAGE_CGENIUS

    # Rick Dangerous
    select BR2_PACKAGE_LIBRETRO_XRICK

    # Flashback
    select BR2_PACKAGE_LIBRETRO_REMINISCENCE                if  BR2_PACKAGE_BATOCERA_TARGET_X86_64_ANY  || BR2_PACKAGE_BATOCERA_BCM27XX

    # Super Flappy Birds
    select BR2_PACKAGE_LIBRETRO_SUPERFLAPPYBIRDS            if  BR2_PACKAGE_BATOCERA_TARGET_X86_64_ANY  || BR2_PACKAGE_BATOCERA_BCM27XX

    # Zelda Classic
    select BR2_PACKAGE_LIBRETRO_ZC210
    select BR2_PACKAGE_LIBRETRO_ZC250X

    # Dinothwar
    select BR2_PACKAGE_LIBRETRO_DINOTHAWR                   if  BR2_PACKAGE_BATOCERA_TARGET_X86_64_ANY  || BR2_PACKAGE_BATOCERA_BCM27XX

    # Minecraft mini-clone
    select BR2_PACKAGE_LIBRETRO_CRAFT                       if  BR2_PACKAGE_BATOCERA_TARGET_X86_64_ANY

    # ChaiScript engine
    select BR2_PACKAGE_LIBRETRO_CHAILOVE                    if  BR2_PACKAGE_BATOCERA_TARGET_X86_64_ANY  || BR2_PACKAGE_BATOCERA_BCM27XX

    select BR2_PACKAGE_LIBRETRO_LOWRESNX                    if  BR2_PACKAGE_BATOCERA_TARGET_X86_64_ANY  || BR2_PACKAGE_BATOCERA_BCM27XX

    select BR2_PACKAGE_ABUSE                                if  BR2_PACKAGE_BATOCERA_TARGET_X86_64_ANY  || BR2_PACKAGE_BATOCERA_BCM27XX

    # Quake 2
    select BR2_PACKAGE_LIBRETRO_VITAQUAKE2                  if  BR2_PACKAGE_BATOCERA_GLES3
    select BR2_PACKAGE_VKQUAKE2                             if  BR2_PACKAGE_BATOCERA_VULKAN && BR2_PACKAGE_XORG7
    select BR2_PACKAGE_YQUAKE2
    select BR2_PACKAGE_YQUAKE2_ROGUE                        if  BR2_PACKAGE_YQUAKE2
    select BR2_PACKAGE_YQUAKE2_XATRIX                       if  BR2_PACKAGE_YQUAKE2
    select BR2_PACKAGE_YQUAKE2_ZAERO                        if  BR2_PACKAGE_YQUAKE2

    # Super Mario War
    select BR2_PACKAGE_LIBRETRO_SUPERBROSWAR

    # EDuke32 requires OpenGL or GLES 3.0
    select BR2_PACKAGE_EDUKE32                              if  BR2_PACKAGE_BATOCERA_GLES3                   # Duke3D / Shadow Warrior / Ion fury

    # GZDoom and Raze require both 64-bit arch (x86,arm,riscv,....) AND OpenGL or GLES 3.0
    select BR2_PACKAGE_GZDOOM                               if  BR2_PACKAGE_BATOCERA_TARGET_X86_64_ANY  || BR2_PACKAGE_BATOCERA_BCM27XX
    select BR2_PACKAGE_RAZE                                 if  BR2_PACKAGE_BATOCERA_TARGET_X86_64_ANY  || BR2_PACKAGE_BATOCERA_BCM27XX

    # ZMusic: standalone library used by gzdoom and raze source ports
    select BR2_PACKAGE_ZMUSIC                               if  BR2_PACKAGE_GZDOOM || BR2_PACKAGE_RAZE

    # Tomb Raider 1/2
    select BR2_PACKAGE_TRX                                  if  BR2_PACKAGE_BATOCERA_TARGET_X86_64_ANY

    # Quake 3
    select BR2_PACKAGE_VKQUAKE3                             if  BR2_PACKAGE_BATOCERA_VULKAN

    # Hydra Castle Labyrinth
    select BR2_PACKAGE_HCL

    # C-Dogs SDL
    select BR2_PACKAGE_CDOGS

    # Turrican clone
    select BR2_PACKAGE_HURRICAN

    # OpenTyrian (shmup game)
    select BR2_PACKAGE_OPENTYRIAN
    select BR2_PACKAGE_OPENTYRIAN2000

    # The Force Engine
    select BR2_PACKAGE_THEFORCEENGINE                       if  BR2_PACKAGE_BATOCERA_TARGET_X86_64_ANY # Requires OpenGL 3.3 or later

    # Return to Castle Wolfenstein
    select BR2_PACKAGE_RTCW                                 if  BR2_PACKAGE_BATOCERA_TARGET_X86_64_ANY  || (BR2_aarch64 && BR2_PACKAGE_BATOCERA_GLES3)

    # Fallout 1 open source engine
    select BR2_PACKAGE_FALLOUT1_CE

    # Fallout 2 open source engine
    select BR2_PACKAGE_FALLOUT2_CE

    # Descent 1 & 2 open source engine
    select BR2_PACKAGE_DXX_REBIRTH                          if  BR2_PACKAGE_HAS_LIBGL

    # Wolfenstein: Enemy Territory
    select BR2_PACKAGE_ETLEGACY                             if  BR2_PACKAGE_BATOCERA_TARGET_X86_64_ANY  || BR2_PACKAGE_BATOCERA_BCM27XX

    # Sonic 3 A.I.R. (Angel Island Revisited)
    select BR2_PACKAGE_SONIC3_AIR                           if  BR2_PACKAGE_BATOCERA_TARGET_X86_64_ANY  || BR2_PACKAGE_BATOCERA_BCM27XX

    # Jazz Jackrabbit
    select BR2_PACKAGE_OPENJAZZ

    # Jazz Jackrabbit 2
    select BR2_PACKAGE_JAZZ2_NATIVE

    # CatacombGL
    select BR2_PACKAGE_CATACOMBGL                           if  BR2_PACKAGE_BATOCERA_TARGET_X86_64_ANY  || BR2_PACKAGE_BATOCERA_BCM27XX

    # Jedi Knight - Dark Forces 2
    # select BR2_PACKAGE_OPENJKDF2                          if  BR2_PACKAGE_BATOCERA_TARGET_X86_64_ANY

    # OpenJK: JediAcademy / Jedi Outcast
    select BR2_PACKAGE_OPENJK                               if  BR2_PACKAGE_BATOCERA_TARGET_X86_64_ANY  || BR2_PACKAGE_BATOCERA_BCM27XX

    # Medal of Honor: Allied Assault
    select BR2_PACKAGE_OPENMOHAA                            if  BR2_PACKAGE_BATOCERA_TARGET_X86_64_ANY

    help
        Ports
