    select BR2_PACKAGE_GST1_PLUGINS_BAD_PLUGIN_MPEG2ENC
    select BR2_PACKAGE_GST1_PLUGINS_BAD_PLUGIN_OPENH264
    select BR2_PACKAGE_GST1_PLUGINS_BAD_PLUGIN_VA           if  BR2_PACKAGE_BATOCERA_TARGET_X86_ANY
    select BR2_PACKAGE_GST1_PLUGINS_BAD_PLUGIN_V4L2CODECS
    select BR2_PACKAGE_GST1_PLUGINS_BAD_PLUGIN_X265
    # Ugly
    select BR2_PACKAGE_GST1_PLUGINS_UGLY
    select BR2_PACKAGE_GST1_PLUGINS_UGLY_PLUGIN_MPEG2DEC
    select BR2_PACKAGE_GST1_PLUGINS_UGLY_PLUGIN_X264
    # VAAPI
    select BR2_PACKAGE_GST1_VAAPI                           if  BR2_PACKAGE_BATOCERA_TARGET_X86_ANY
    select BR2_PACKAGE_GST1_VAAPI_ENCODERS                  if  BR2_PACKAGE_BATOCERA_TARGET_X86_ANY
    select BR2_PACKAGE_INTEL_MEDIADRIVER                    if  BR2_PACKAGE_BATOCERA_TARGET_X86_ANY     && !BR2_PACKAGE_BATOCERA_LIB32

