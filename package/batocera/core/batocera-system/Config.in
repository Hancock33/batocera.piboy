config BR2_PACKAGE_BATOCERA_XWAYLAND
    bool "batocera.linux xwayland packages selection"

    # Xorg emulation layer of Wayland
    select BR2_PACKAGE_XORG7
    select BR2_PACKAGE_CAIRO
    select BR2_PACKAGE_LIBXCB
    select BR2_PACKAGE_XCB_UTIL_CURSOR
    select BR2_PACKAGE_XLIB_LIBX11
    select BR2_PACKAGE_XLIB_LIBXCURSOR
    select BR2_PACKAGE_XWAYLAND
    select BR2_PACKAGE_WLROOTS_X11
    select BR2_PACKAGE_WLROOTS_XWAYLAND
    select BR2_PACKAGE_XAPP_XINPUT
    select BR2_PACKAGE_XAPP_XINPUT_CALIBRATOR

    # Xorg apps
    select BR2_PACKAGE_BATOCERA_DESKTOPAPPS                 if !BR2_PACKAGE_BATOCERA_LIB32             # batocera applications config and scripts
    select BR2_PACKAGE_LIBGTK3                              if !BR2_PACKAGE_BATOCERA_LIB32             # gtk3 library
    select BR2_PACKAGE_L3AFPAD                              if !BR2_PACKAGE_BATOCERA_LIB32             # gtk3 text editor
    select BR2_PACKAGE_PCMANFM                              if !BR2_PACKAGE_BATOCERA_LIB32             # file manager
    select BR2_PACKAGE_GVFS                                 if !BR2_PACKAGE_BATOCERA_LIB32             # file systems (trash, smb, ... in pcmanfm)
    select BR2_PACKAGE_ADWAITA_ICON_THEME_LIGHT             if !BR2_PACKAGE_BATOCERA_LIB32             # theme for file manager
    select BR2_PACKAGE_XTERM                                if !BR2_PACKAGE_BATOCERA_LIB32             # terminal

config BR2_PACKAGE_BATOCERA_XORG
    bool "batocera.linux xorgs packages selection"

    select BR2_PACKAGE_XORG7
    select BR2_PACKAGE_XSERVER_XORG_SERVER                  if !BR2_PACKAGE_BATOCERA_LIB32

    # xwayland based architecture (no more ddx drivers)
    select BR2_PACKAGE_LIBEPOXY                             # required to enable xorg glamor
    select BR2_PACKAGE_WAYLAND_PROTOCOLS                    if  BR2_PACKAGE_BATOCERA_WAYLAND
    select BR2_PACKAGE_XLIB_LIBXCOMPOSITE

    # drivers
    select BR2_PACKAGE_XDRIVER_XF86_INPUT_EVDEV             if !BR2_PACKAGE_BATOCERA_LIB32
    select BR2_PACKAGE_XDRIVER_XF86_INPUT_LIBINPUT          if !BR2_PACKAGE_BATOCERA_LIB32
    select BR2_PACKAGE_XDRIVER_XF86_INPUT_SYNAPTICS         if !BR2_PACKAGE_BATOCERA_LIB32

    # GPU drivers (needed for old Nvidia & AMD cards for edid handshake with display)
    select BR2_PACKAGE_XDRIVER_XF86_VIDEO_AMDGPU            if  BR2_PACKAGE_BATOCERA_TARGET_X86_ANY     && !BR2_PACKAGE_BATOCERA_LIB32
    select BR2_PACKAGE_XDRIVER_XF86_VIDEO_ATI               if  BR2_PACKAGE_BATOCERA_TARGET_X86_ANY     && !BR2_PACKAGE_BATOCERA_LIB32
    select BR2_PACKAGE_XDRIVER_XF86_VIDEO_NOUVEAU           if  BR2_PACKAGE_BATOCERA_TARGET_X86_ANY     && !BR2_PACKAGE_BATOCERA_LIB32
    # select BR2_PACKAGE_XDRIVER_XF86_VIDEO_INTEL           if  BR2_PACKAGE_BATOCERA_TARGET_X86_ANY     && !BR2_PACKAGE_BATOCERA_LIB32

    # nvidia xorg packages are selected by batocera-nvidia package

    # applications
    select BR2_PACKAGE_XAPP_SETXKBMAP                       if !BR2_PACKAGE_BATOCERA_LIB32
    select BR2_PACKAGE_XAPP_XEV                             if !BR2_PACKAGE_BATOCERA_LIB32
    select BR2_PACKAGE_XAPP_XINIT                           if !BR2_PACKAGE_BATOCERA_LIB32
    select BR2_PACKAGE_XAPP_XINPUT                          if !BR2_PACKAGE_BATOCERA_LIB32
    select BR2_PACKAGE_XAPP_XRANDR                          if !BR2_PACKAGE_BATOCERA_LIB32              # required for resolution manipulation
    select BR2_PACKAGE_XAPP_XSET                            if !BR2_PACKAGE_BATOCERA_LIB32              # X11 Xset command
    select BR2_PACKAGE_XAPP_XBACKLIGHT                      if !BR2_PACKAGE_BATOCERA_LIB32              # set the backlight

    select BR2_PACKAGE_BATOCERA_DESKTOPAPPS                 if !BR2_PACKAGE_BATOCERA_LIB32              # batocera applications config and scripts
    select BR2_PACKAGE_LIBGTK3                              if !BR2_PACKAGE_BATOCERA_LIB32              # gtk3 library
    select BR2_PACKAGE_L3AFPAD                              if !BR2_PACKAGE_BATOCERA_LIB32              # gtk3 text editor
    select BR2_PACKAGE_PCMANFM                              if !BR2_PACKAGE_BATOCERA_LIB32              # file manager
    select BR2_PACKAGE_GVFS                                 if  BR2_PACKAGE_PCMANFM                     # file systems (trash, smb, ... in pcmanfm)
    select BR2_PACKAGE_ADWAITA_ICON_THEME_LIGHT             if  BR2_PACKAGE_PCMANFM                     # theme for file manager
    select BR2_PACKAGE_XTERM                                if !BR2_PACKAGE_BATOCERA_LIB32              # terminal
    select BR2_PACKAGE_OPENBOX                              if !BR2_PACKAGE_BATOCERA_LIB32              # window manager
    select BR2_PACKAGE_UNCLUTTER                            if !BR2_PACKAGE_BATOCERA_LIB32              # hide mouse
    select BR2_PACKAGE_TOUCHEGG                             if !BR2_PACKAGE_BATOCERA_LIB32              # touchscreen extended gestures

    # Openbox wallpaper
    select BR2_PACKAGE_IMLIB2_X                             if !BR2_PACKAGE_BATOCERA_LIB32
    select BR2_PACKAGE_IMLIB2_JPEG                          if !BR2_PACKAGE_BATOCERA_LIB32
    select BR2_PACKAGE_IMLIB2_PNG                           if !BR2_PACKAGE_BATOCERA_LIB32
    select BR2_PACKAGE_IMLIB2_GIF                           if !BR2_PACKAGE_BATOCERA_LIB32
    select BR2_PACKAGE_FEH                                  if !BR2_PACKAGE_BATOCERA_LIB32

    # Mouse Cursor
    select BR2_PACKAGE_XDATA_XCURSOR_THEMES                 if !BR2_PACKAGE_BATOCERA_LIB32
    select BR2_PACKAGE_XAPP_XRDB                            if !BR2_PACKAGE_BATOCERA_LIB32

    # vendor neutral GL dispatch library
    # already set by nvidia for x86_64, but required on x86 for pcsx2
    # required for RPi4 OpenGL stack
    select BR2_PACKAGE_LIBGLVND                             if  BR2_PACKAGE_BATOCERA_TARGET_X86_ANY     || BR2_PACKAGE_BATOCERA_SBC_XORG

